{
  "name": "file-transfer-app-desktop",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:backend\" \"npm:dev:frontend\" \"npm:dev:electron\"",
    "dev:backend": "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:electron": "wait-on tcp:5000 tcp:5173 && cross-env ELECTRON_START_URL=http://localhost:5173 electron .",
    "build": "npm --prefix backend install && npm run build:frontend && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder",
    "build:frontend": "npm --prefix frontend run build",
    "start": "electron ."
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^37.2.1",
    "electron-builder": "^26.0.12",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.transferhub.desktop",
    "productName": "TransferHub",
    "files": [
      "electron/**/*",
      "frontend/dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!uploads/**",
          "!.env",
          "!node_modules/.bin"
        ]
      },
      {
        "from": "backend/node_modules",
        "to": "backend/node_modules",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false
    }
  }
}
